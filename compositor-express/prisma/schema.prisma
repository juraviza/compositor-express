generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
    output = "./node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Lyric {
  id           String       @id @default(uuid()) @db.Uuid
  title        String
  content      String       @db.Text
  originalIdea String?      @db.Text
  theme        String?
  emotion      String?
  style        String?
  isFavorite   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  suggestions  Suggestion[]

  @@index([theme])
  @@index([emotion])
  @@index([style])
  @@index([isFavorite])
  @@index([createdAt])
}

model Video {
  id            String   @id @default(uuid()) @db.Uuid
  lyricId       String?  @db.Uuid
  title         String
  audioPath     String?  // S3 cloud_storage_path of the source MP3
  videoPath     String?  // S3 cloud_storage_path of the generated MP4
  videoSubtitlesPath String? // S3 cloud_storage_path of the subtitled variant
  subtitlesConfig String? @db.Text // JSON: { lines, fontFamily, fontSize, color, position }
  format        String   // 'vertical' | 'horizontal'
  template      String   // 'pasion' | 'noche' | 'duende' | 'fiesta'
  segmentStart  Float    @default(0)
  segmentEnd    Float    @default(60)
  durationSec   Float    @default(60)
  audioDurationSec Float?
  status        String   @default("pending") // pending | processing | ready | failed
  errorMsg      String?
  lyricsText    String   @db.Text
  artistName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([lyricId])
  @@index([createdAt])
  @@index([status])
}

model Suggestion {
  id             String    @id @default(uuid()) @db.Uuid
  lyricId        String    @db.Uuid
  originalText   String
  suggestedTexts String[]
  positionStart  Int
  positionEnd    Int
  severity       String
  reason         String
  appliedText    String?
  appliedAt      DateTime?
  createdAt      DateTime  @default(now())
  lyric          Lyric     @relation(fields: [lyricId], references: [id], onDelete: Cascade)

  @@index([lyricId])
  @@index([severity])
}
