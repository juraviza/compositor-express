# Compositor Express - Environment Variables
# Copia este archivo a .env y llena los valores

# ========================
# BASE DE DATOS (Neon)
# ========================
# Ve a https://neon.tech → tu proyecto → Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ========================
# LLM (Groq - gratis)
# ========================
# Ve a https://console.groq.com → API Keys → Create
GROQ_API_KEY=tu_groq_api_key

# ========================
# DEEPSEEK (opcional - para letras)
# ========================
# Ve a https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=tu_deepseek_api_key

# ========================
# APIs DE VIDEO (stock footage)
# ========================
# Pixabay: https://pixabay.com → API Key
PIXABAY_API_KEY=tu_pixabay_api_key

# Pexels: https://www.pexels.com → API Key
PEXELS_API_KEY=tu_pexels_api_key

# ========================
# STORAGE (Backblaze B2)
# ========================
# Ve a https://www.backblaze.com → B2 Cloud Storage → Application Keys
B2_ACCOUNT_ID=tu_account_id
B2_ACCESS_KEY_ID=tu_access_key
B2_SECRET_ACCESS_KEY=tu_secret_key
B2_BUCKET_NAME=nombre_bucket
B2_REGION=us-west-002
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com

# ========================
# NOTAS
# ========================
# - Todas las APIs son necesarias para que el proyecto funcione
# - Groq es gratis (hasta 30 req/min)
# - Neon PostgreSQL tiene plan gratis
# - Backblaze B2 tiene 10GB gratis
# - Pixabay y Pexels tienen planes gratuitos
