{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "assets/**/*", "outDir": "dist/src" },
      { "include": "logo-aureo.png", "outDir": "dist/src" },
      { "include": "*.otf", "outDir": "dist/src" },
      { "include": "*.ttf", "outDir": "dist/src" }
    ],
    "watchAssets": false
  }
}
